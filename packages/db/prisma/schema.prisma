generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String         @id @default(uuid())
  address    String         @unique
  kind       AccountKind    @default(REAL)
  usdBalance Int            @default(0)
  orders     OrderHistory[]
  positions  Position[]

  @@index([address])
}

model Market {
  id                    String         @id @default(uuid())
  title                 String
  description           String
  resolutionDescription String
  yesOrderbook          Json
  noOrderbook           Json
  totalQty              Int            @default(0)
  resolution            PositionType?
  orders                OrderHistory[]
  positions             Position[]
}

model Position {
  id       String       @id @default(uuid())
  userId   String
  marketId String
  type     PositionType
  qty      Int
  market   Market       @relation(fields: [marketId], references: [id])
  user     User         @relation(fields: [userId], references: [id])

  @@unique([userId, marketId, type])
  @@index([marketId])
}

model OrderHistory {
  id        String    @id @default(uuid())
  orderType OrderType
  qty       Int
  price     Int
  userId    String
  marketId  String
  createdAt DateTime  @default(now())
  market    Market    @relation(fields: [marketId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([marketId])
}

enum OrderType {
  BUY
  SELL
  SPLIT
  MERGE
}

enum PositionType {
  YES
  NO
}

enum AccountKind {
  REAL
  DEMO
}
